# Poker44 miner config for THIS fork (uid13).
#   cp miner.env.example miner.env   # then fill in the values below
# Launch with the wrapper (it sources miner.env and pins the commit):
#   ./run_p44_miner.sh
# miner.env is gitignored so your local edits never collide with upstream.

# --- Wallet / chain (consumed by scripts/miner/run/run_miner.sh) ---
export WALLET_NAME="my_cold"
export HOTKEY="my_uid13_hotkey"
export AXON_PORT="8096"
export PM2_NAME="poker44_miner_uid13"
# Space-separated validator hotkeys allowed to query you (recommended).
# Leave empty to fall back to the validator-permit rule.
export ALLOWED_VALIDATOR_HOTKEYS=""

# --- Model identity (MUST match the public code you serve) ---
# Your OWN public fork — NEVER https://github.com/Poker44/Poker44-subnet
export POKER44_MODEL_REPO_URL="https://github.com/hanamichi030/fast_track"
# Anything except the reserved name "poker44-reference-heuristic"
export POKER44_MODEL_NAME="poker13-lgbm"
export POKER44_MODEL_VERSION="1"
export POKER44_MODEL_OPEN_SOURCE="true"
export POKER44_MODEL_TRAINING_DATA_STATEMENT="Tuned LightGBM classifier (1200 trees, lr 0.02, 63 leaves) over 180 sanitization-invariant behavioral features (cross-hand duplication signatures, entropies, structural and aggression aggregates), trained on the public Poker44 benchmark (labels from groundTruth), with an isotonic calibrator fit on grouped-by-date out-of-fold predictions. Training hands pass through prepare_hand_for_miner so training matches serving. Output is a monotone within-batch decision layer that lets a small top fraction of each batch cross 0.5. No domain adaptation and no query-chunk fitting are used."
export POKER44_MODEL_PRIVATE_DATA_ATTESTATION="No validator-only evaluation labels or private data are used. The model trains only on public Poker44 benchmark labels. No test-time domain adaptation or query-chunk fitting is applied; each received chunk is scored independently up to a monotone within-batch output transform."

# NOTE: POKER44_MODEL_REPO_COMMIT is set automatically by run_p44_miner.sh to the
# current git HEAD, so the served commit always matches the running code. Do not
# hand-set it here.
